{
  "name": "pi-todo",
  "version": "0.1.0",
  "description": "A stateful todo-list extension for pi.",
  "type": "module",
  "files": [
    "index.ts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SteelDynamite/pi-todo.git"
  },
  "bugs": {
    "url": "https://github.com/SteelDynamite/pi-todo/issues"
  },
  "homepage": "https://github.com/SteelDynamite/pi-todo#readme",
  "engines": {
    "node": ">=22"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "test:pack": "npm pack --dry-run --json",
    "validate": "npm run typecheck && npm test && npm run test:pack"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "todo",
    "tasks"
  ],
  "author": "SteelDynamite",
  "license": "MIT",
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.9.3"
  }
}
